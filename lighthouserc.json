{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:8080/index.html",
        "http://localhost:8080/over-ons.html",
        "http://localhost:8080/werkwijze.html",
        "http://localhost:8080/contact.html",
        "http://localhost:8080/particuliere-verhuizing.html",
        "http://localhost:8080/zakelijke-verhuizing.html",
        "http://localhost:8080/spoedverhuizing.html",
        "http://localhost:8080/m3-calculator.html"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "formFactor": "desktop",
        "screenEmulation": {
          "mobile": false,
          "width": 1350,
          "height": 940,
          "deviceScaleFactor": 1,
          "disabled": false
        },
        "throttling": {
          "rttMs": 40,
          "throughputKbps": 10240,
          "cpuSlowdownMultiplier": 1,
          "requestLatencyMs": 0,
          "downloadThroughputKbps": 0,
          "uploadThroughputKbps": 0
        },
        "throttlingMethod": "simulate",
        "onlyCategories": [
          "performance",
          "accessibility",
          "best-practices",
          "seo"
        ]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.95 }],
        "categories:accessibility": ["error", { "minScore": 1.0 }],
        "categories:seo": ["error", { "minScore": 1.0 }],
        "categories:best-practices": ["error", { "minScore": 0.95 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
